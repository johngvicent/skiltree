---
import Button from './Button.astro';
// No props needed, this component manages its own state on the client side
---

<div class="search-container">
  <input 
    type="text" 
    id="searchBox" 
    placeholder="🔍 Resaltar categorías o recursos..." 
    autocomplete="off"
  />
  <Button id="expandAllBtn" text="Expandir Todo" variant="pulse" />
  <Button id="collapseAllBtn" text="Colapsar Todo" variant="pulse" />
</div>

<style>
  .search-container {
    margin: 0;
    max-width: 100%;
    display: flex;
    gap: 8px;
    align-items: center;
    padding: 0;
    flex-wrap: nowrap;
  }

  #searchBox {
    flex: 1;
    min-width: 150px;
    max-width: 600px;
    width: clamp(150px, 40vw, 600px);
    padding: 8px 16px;
    font-size: 14px;
    background-color: #2a2a2a;
    border: 2px solid #444;
    border-radius: 5px;
    color: #e0e0e0;
    outline: none;
    transition: all 0.3s ease;
  }

  #searchBox:focus {
    border-color: #00d4ff;
    box-shadow: 0 0 15px rgba(0, 212, 255, 0.2);
  }

  @media (max-width: 768px) {
    .search-container {
      flex-wrap: wrap;
      justify-content: center;
    }

    #searchBox {
      width: 100%;
      max-width: 100%;
      flex-basis: 100%;
    }
  }
</style>
